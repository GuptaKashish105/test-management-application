# Copy this file to .env and fill in real values.
# See docs/api/backend-base-url.md for the staging backend URL.

VITE_API_BASE_URL=

# Local development only. When "true", every API call is served from local
# mock data instead of the real backend (src/services/demoMode) — useful
# when the live backend is unreachable. Leave unset/false for real usage.
# Never set this in a deployed/production environment.
VITE_DEMO_MODE=false
